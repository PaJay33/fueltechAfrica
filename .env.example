# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://fueltech:fueltech_dev_password@localhost:5432/fueltech_db?schema=public"
SHADOW_DATABASE_URL="postgresql://fueltech:fueltech_dev_password@localhost:5432/fueltech_db_shadow"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=fueltech_redis_password

# JWT Secrets
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Cookie Settings
COOKIE_SECRET=your-cookie-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Wave Payment API (Senegal)
WAVE_API_URL=https://api.wave.com
WAVE_API_KEY=your-wave-api-key
WAVE_API_SECRET=your-wave-api-secret
WAVE_MERCHANT_ID=your-wave-merchant-id
WAVE_WEBHOOK_SECRET=your-wave-webhook-secret

# IoT Simulator Settings
IOT_SIMULATOR_ENABLED=true
IOT_SIMULATOR_INTERVAL=5000

# Station Settings
DEFAULT_FUEL_PRICE_SUPER=650
DEFAULT_FUEL_PRICE_DIESEL=580
DEFAULT_FUEL_PRICE_ORDINAIRE=520

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600000

# Monitoring & Health Check
HEALTH_CHECK_INTERVAL=60000

# Webhook Retry Settings
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000
